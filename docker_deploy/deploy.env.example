# Deployment branch. Leave as current default branch if your repo uses main.
DEPLOY_BRANCH=main

# Git remote name.
GIT_REMOTE=origin

# Docker image and container names.
IMAGE_NAME=mkdocs-tao
CONTAINER_NAME=mkdocs-tao

# Host port 8493 -> container port 80.
HOST_PORT=8493
CONTAINER_PORT=80

# How often cron should run update.sh.
CRON_EXPR="*/10 * * * *"

# Log file used by install_cron.sh.
UPDATE_LOG_FILE="$SCRIPT_DIR/update.log"